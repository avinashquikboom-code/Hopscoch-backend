# =============================================================================
# backend.env — RUNTIME secrets for the Hopscotch backend container.
# Copy to /opt/hopscotch/backend.env on the VPS and fill in REAL values.
# NEVER commit the filled-in file. Injected via --env-file at container start;
# nothing here is baked into the image.
#
# Postgres runs on the VPS host, so DATABASE_URL should use host.docker.internal:
#   postgresql://USER:PASS@host.docker.internal:5432/hopscotch
# =============================================================================

NODE_ENV=production
PORT=5000
API_URL=https://api.fciseller.com

DATABASE_URL=postgresql://USER:PASS@host.docker.internal:5432/hopscotch

JWT_SECRET=
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_JWT_SECRET=
ADMIN_REFRESH_SECRET=
WEBSITE_JWT_SECRET=
WEBSITE_REFRESH_SECRET=
MOBILE_JWT_SECRET=
MOBILE_REFRESH_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

GEMINI_API_KEY=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

REDIS_URL=

# Comma-separated allowed origins (storefront + admin).
CLIENT_URL=https://fciseller.com
CORS_ORIGIN=https://admin.fciseller.com,https://fciseller.com,https://www.fciseller.com,http://localhost:3000,http://localhost:3001
