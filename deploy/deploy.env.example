# =============================================================================
# Deploy toolkit config — copy to /opt/hopscotch/deploy.env on the VPS.
# Sourced by config.sh and all deploy-*.sh scripts. Tune values here only.
# =============================================================================

# --- AWS / ECR ---
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=546941058055
ECR_REGISTRY=546941058055.dkr.ecr.ap-south-1.amazonaws.com

# Repository names as they exist in ECR (create these once: see README).
BACKEND_REPO=hopscotch-backend
ADMIN_REPO=hopscotch-admin
ECOM_REPO=hopscotch-ecom

# Image tag to deploy (latest, or a specific git sha for rollbacks).
IMAGE_TAG=latest

# --- Docker network (isolated from the HRM stack's hrm-net) ---
DOCKER_NETWORK=hopscotch-net

# --- Container names ---
BACKEND_CONTAINER=hopscotch-backend
ADMIN_CONTAINER=hopscotch-admin
ECOM_CONTAINER=hopscotch-ecom

# --- Host ports (bound to 127.0.0.1; must NOT clash with HRM's 3000/5004) ---
BACKEND_PORT=5005      # container listens on 5000
ADMIN_PORT=3001        # container listens on 3000
ECOM_PORT=3002         # container listens on 3000

# --- Env files (runtime secrets, created separately on the VPS) ---
BACKEND_ENV_FILE=/opt/hopscotch/backend.env
ADMIN_ENV_FILE=/opt/hopscotch/admin.env
ECOM_ENV_FILE=/opt/hopscotch/ecom.env

# =============================================================================
# Resource limits. The host is SHARED with the HRM stack on a 2 vCPU / ~1.9GB
# box, so keep these lean. Verify free RAM with `free -m` before deploying all
# three (see README "Capacity" section). CPU is in cores (1.0 = one full core).
# =============================================================================

# Backend (Node/Express + Prisma)
BACKEND_CPUS=0.75
BACKEND_MEMORY=512m
BACKEND_MEMORY_RESERVATION=256m

# Admin panel (Next.js standalone — light at runtime)
ADMIN_CPUS=0.5
ADMIN_MEMORY=384m
ADMIN_MEMORY_RESERVATION=192m

# Storefront (Next.js standalone — light at runtime)
ECOM_CPUS=0.5
ECOM_MEMORY=384m
ECOM_MEMORY_RESERVATION=192m
