# =============================================================================
# ecom.env — RUNTIME config for the Hopscotch storefront (Next.js) container.
# Copy to /opt/hopscotch/ecom.env on the VPS. Injected via --env-file.
# =============================================================================

NODE_ENV=production
PORT=3000

# Backend origin the storefront calls (resolved at runtime, not baked in).
BACKEND_API_URL=https://api.fciseller.com

# Any NEXT_PUBLIC_* values the storefront needs at runtime go here as well.
# NEXT_PUBLIC_API_URL=https://api.fciseller.com
