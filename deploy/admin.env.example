# =============================================================================
# admin.env — RUNTIME config for the Hopscotch admin panel (Next.js) container.
# Copy to /opt/hopscotch/admin.env on the VPS. Injected via --env-file.
# =============================================================================

NODE_ENV=production
PORT=3000

# If the admin app proxies /api/* to the backend via next.config rewrites,
# set the backend origin here (resolved at runtime, not baked in).
BACKEND_API_URL=https://api.fciseller.com

# Any NEXT_PUBLIC_* values the admin needs at runtime go here as well.
# NEXT_PUBLIC_API_URL=https://api.fciseller.com
